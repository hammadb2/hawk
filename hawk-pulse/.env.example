# HAWK Pulse Engine — environment variables

# PostgreSQL (async driver for SQLAlchemy)
DATABASE_URL=postgresql+asyncpg://hawk:hawk@localhost:5432/hawk_pulse
DATABASE_URL_SYNC=postgresql://hawk:hawk@localhost:5432/hawk_pulse

# Certstream CT log WebSocket URL
CERTSTREAM_URL=wss://certstream.calidog.io/

# Scanner tool binaries (leave empty to use $PATH)
NAABU_BIN=
HTTPX_BIN=
NUCLEI_BIN=

# Ports to scan (comma-separated)
NAABU_PORTS=80,443,8080,8443,3000,4443,22,21,3306,5432,6379,27017,3389

# Subprocess timeout per tool invocation (seconds)
LAYER_TIMEOUT_SEC=60

# Max concurrent micro-scans
MICROSCAN_WORKERS=4

# HAWK Guard — AI Remediation (Step 2)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
REMEDIATION_TIMEOUT_SEC=60
REMEDIATION_ENABLED=true
