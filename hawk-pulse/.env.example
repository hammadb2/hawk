# HAWK Pulse Engine — environment variables

# PostgreSQL — supports both local and Supabase URLs.
# The app auto-converts postgresql:// to postgresql+asyncpg:// for the async driver.
# For Supabase, paste the connection string from Dashboard → Settings → Database → URI.
DATABASE_URL=postgresql://hawk:hawk@localhost:5432/hawk_pulse
# DATABASE_URL_SYNC is optional — falls back to DATABASE_URL if not set.

# Certstream CT log WebSocket URL
CERTSTREAM_URL=wss://certstream.calidog.io/

# Scanner tool binaries (leave empty to use $PATH)
NAABU_BIN=
HTTPX_BIN=
NUCLEI_BIN=

# Ports to scan (comma-separated)
NAABU_PORTS=80,443,8080,8443,3000,4443,22,21,3306,5432,6379,27017,3389

# Subprocess timeout per tool invocation (seconds)
LAYER_TIMEOUT_SEC=60

# Max concurrent micro-scans
MICROSCAN_WORKERS=4

# HAWK Guard — AI Remediation (Step 2)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
REMEDIATION_TIMEOUT_SEC=60
REMEDIATION_ENABLED=true

# HAWK Sentinel — AI Red Team (Step 3)
SENTINEL_ENABLED=true
SENTINEL_LLM_API_KEY=           # DeepSeek or OpenAI API key for agent swarm
SENTINEL_LLM_BASE_URL=https://api.openai.com/v1
SENTINEL_LLM_MODEL=gpt-4o-mini
SENTINEL_DOCKER_IMAGE=kalilinux/kali-rolling
SENTINEL_CONTAINER_TIMEOUT=3600  # Max audit duration (seconds)
SENTINEL_MAX_CONCURRENT=2        # Max concurrent audits
