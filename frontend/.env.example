# HAWK Frontend — copy to .env.local

# Backend API URL (required for auth, scans, etc.)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Production example:
# NEXT_PUBLIC_API_URL=https://api.hawk.akbstudios.com

# HAWK CRM (Phase 1+) — Supabase Auth + data
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional: Sentry for CRM shell
# NEXT_PUBLIC_SENTRY_DSN=
