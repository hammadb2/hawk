# HAWK Frontend — copy to .env.local

# Backend API URL (required for auth, scans, etc.)
NEXT_PUBLIC_API_URL=http://localhost:8000
# Server-only: same Railway URL — used by Next.js /api/guarantee/* proxy (so the browser does not call Railway directly).
# On Vercel, set to your FastAPI base URL (required for guarantee verification emails to send).
# HAWK_API_URL=https://your-api.up.railway.app
# Canonical browser origin for magic links & redirects (production: https://securedbyhawk.com)
NEXT_PUBLIC_SITE_URL=https://securedbyhawk.com
# Enterprise pricing — Cal.com (same as backend CAL_COM_BOOKING_URL)
# NEXT_PUBLIC_CAL_COM_BOOKING_URL=https://cal.com/your-org/hawk-enterprise

# Production (Railway API):
# NEXT_PUBLIC_API_URL=https://hawk-production.up.railway.app

# Vercel Cron (server-only — set in Vercel dashboard, not NEXT_PUBLIC_*):
# Same value as backend HAWK_CRM_CRON_SECRET / HAWK_CRON_SECRET / CRON_SECRET so /api/cron/* routes can call Railway.
# CRON_SECRET=

# HAWK CRM (Phase 1+) — Supabase Auth + data (same project as backend SUPABASE_URL)
NEXT_PUBLIC_SUPABASE_URL=
# From Supabase Dashboard → Project Settings → API → anon public key (not the service role)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional: Sentry for CRM shell
# NEXT_PUBLIC_SENTRY_DSN=
