# HAWK Frontend — copy to .env.local

# Backend API URL (required for auth, scans, etc.)
NEXT_PUBLIC_API_URL=http://localhost:8000
# Canonical browser origin for magic links & redirects (production: https://securedbyhawk.com)
NEXT_PUBLIC_SITE_URL=https://securedbyhawk.com

# Production (Railway API):
# NEXT_PUBLIC_API_URL=https://hawk-production.up.railway.app

# HAWK CRM (Phase 1+) — Supabase Auth + data (same project as backend SUPABASE_URL)
NEXT_PUBLIC_SUPABASE_URL=
# From Supabase Dashboard → Project Settings → API → anon public key (not the service role)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional: Sentry for CRM shell
# NEXT_PUBLIC_SENTRY_DSN=
