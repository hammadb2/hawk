# HAWK Core API — copy to .env and set values

# Required for JWT and sessions
HAWK_SECRET_KEY=your-secret-key-min-32-chars

# Database (default: SQLite in project root)
# DATABASE_URL=sqlite:///./hawk.db
# DATABASE_URL=postgresql://user:pass@host:5432/hawk

# Scanner relay — base URL only; backend appends /scan (see services/scanner.py)
# Local dev default is legacy Ghost. On Railway: set on the MAIN API service to your
# hawk-scanner-v2 deployment URL (e.g. https://intelligent-rejoicing-production.up.railway.app
# or whatever Railway shows for that service — no trailing slash, no /scan).
HAWK_SCANNER_RELAY_URL=http://178.104.27.211:8002
# httpx timeout when calling the relay (seconds; must cover full pipeline, CRM uses ~295s client-side)
HAWK_SCANNER_TIMEOUT=300

# Stripe (live)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_AGENCY=price_...
# Optional — HAWK Shield subscription price id (webhook line_items match)
# STRIPE_PRICE_SHIELD=price_...

# Stripe test mode — embedded /checkout + Railway; STRIPE_WEBHOOK_SECRET_TEST verifies test webhooks
STRIPE_SECRET_KEY_TEST=sk_test_...
STRIPE_WEBHOOK_SECRET_TEST=whsec_...
STRIPE_PRICE_SHIELD_TEST=price_...
# Optional — legacy test Starter price (subscription webhooks only; not used by checkout-public-test)
# STRIPE_PRICE_STARTER_TEST=price_...

# Shield onboarding — Cal.com (shown in SMS + welcome email)
# CAL_COM_BOOKING_URL=https://cal.com/your-team/onboarding

# Frontend URL (checkout/portal redirects)
HAWK_BASE_URL=https://securedbyhawk.com

# OpenAI — Ask HAWK, portal AI advisor, threat briefings, benchmark copy, Charlotte outbound emails, weekly attacker sim
OPENAI_API_KEY=sk-...
# Default model for most features (override per feature below if needed)
OPENAI_MODEL=gpt-4o
# Optional: different model for dashboard Ask HAWK only
# HAWK_ASK_OPENAI_MODEL=gpt-4o-mini
# Optional: Charlotte cron email generation (defaults to OPENAI_MODEL)
# CHARLOTTE_OPENAI_MODEL=gpt-4o
# Optional: portal advisor / briefings / benchmark (defaults to OPENAI_MODEL)
# HAWK_PORTAL_OPENAI_MODEL=gpt-4o

# Legacy DeepSeek (unused when OPENAI_API_KEY is set)
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Charlotte (Revenue-Ops) — welcome email, digests
CHARLOTTE_URL=http://46.225.168.75:8001/agent/charlotte
CHARLOTTE_API_KEY=akb-revenue-ops-2026

# Optional: PDF output directory for reports
# HAWK_REPORTS_DIR=./reports

# Cron (scheduled scans + trial expiry + Shield onboarding sequences). Header: X-Cron-Secret: <value>
# POST /api/crm/cron/onboarding-sequences — daily ~14:00 UTC (cron-job.org)
# HAWK_CRON_SECRET=your-cron-secret
# Same value may be set as CRON_SECRET on Railway (alias — both work).

# HaveIBeenPwned — breach check feature
HIBP_API_KEY=your-hibp-api-key

# ── CRM (Supabase service role — webhooks, aging cron). Never expose service role to the browser.
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# JWT secret (Settings → API → JWT Secret) — local HS256 verify for Bearer tokens. If unset or wrong, API falls back to Supabase GET /auth/v1/user when SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY are set (portal billing).
# SUPABASE_JWT_SECRET=your-jwt-secret
# Public CRM URL for invite redirects + SMS links (no trailing slash)
# CRM_PUBLIC_BASE_URL=https://securedbyhawk.com
# OpenPhone — SMS alerts (CRM Charlotte, Shield, pipeline, monitoring)
# OPENPHONE_API_KEY=
# OPENPHONE_FROM_NUMBER=
# CEO phone E.164 for Charlotte / monitor / escalation alerts (default +18259458282 if unset in code paths that use it)
# CRM_CEO_PHONE_E164=+18259458282
# VA team SMS for Charlotte reply routing
# VA_PHONE_NUMBER=
# CRM email events — POST /api/crm/webhooks/email-events with header X-CRM-Webhook-Secret
# CRM_EMAIL_WEBHOOK_SECRET=generate-a-long-random-string
# Charlotte enrichment script (hawk-scanner-v2/scripts/charlotte_enrichment.py) also uses:
# SCANNER_URL=https://intelligent-rejoicing-production.up.railway.app
# OPENAI_API_KEY=sk-...   # same as main API key if one key for all
# SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY (suppressions + optional)
# CHARLOTTE_SENDER_NAME=Your Name
#
# Charlotte daily automation — POST /api/crm/cron/charlotte-run (same X-Cron-Secret as other crons; e.g. cron-job.org 8am MST)
# APOLLO_API_KEY=
# APOLLO_API_BASE=https://api.apollo.io/api/v1
# ZEROBOUNCE_API_KEY=
# SMARTLEAD_API_KEY=
# SMARTLEAD_CAMPAIGN_ID=          # or set crm_settings.smartlead_campaign_id in Supabase
# SMARTLEAD_API_BASE=https://server.smartlead.ai/api/v1
# CHARLOTTE_AUTOMATION_DRY_RUN=0  # set to 1 to skip Apollo/ZB/Smartlead/Scanner/OpenAI (still logs + CEO SMS if Supabase OK)
# REDIS_URL=redis://...   # optional: Charlotte fast-scan cache + scanner queue depth health
# VA_PHONE_NUMBER=+1...  # Charlotte reply routing for VA team (SMS via OpenPhone)
# CAL_COM_BOOKING_URL=https://cal.com/your/onboarding
# CRM aging cron — same X-Cron-Secret header; also accepts HAWK_CRM_CRON_SECRET / HAWK_CRON_SECRET
# POST /api/crm/cron/onboarding-drip — drip emails (Phase 2B)
# POST /api/crm/cron/stale-pipeline — 48h stale deal SMS to rep (Phase 2C)

# Resend — client portal onboarding (verify securedbyhawk.com in Resend Dashboard → Domains)
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=HAWK Security <noreply@securedbyhawk.com>
# Optional; defaults to RESEND_FROM_EMAIL
# RESEND_GUARANTEE_FROM=HAWK Security <noreply@securedbyhawk.com>

# Portal AI model override (threat briefings, benchmark, attacker sim; defaults to OPENAI_MODEL)
# HAWK_PORTAL_OPENAI_MODEL=gpt-4o

# WeasyPrint — PIPEDA PDF on API host (pip install weasyprint + system libs)
# Ubuntu/Railway: install weasyprint dependencies per WeasyPrint docs

# Phase 4 crons (same X-Cron-Secret; Vercel /api/cron/* proxies to Railway if NEXT_PUBLIC_API_URL is API)
# POST /api/crm/cron/rep-health-score — daily rep health → profiles.health_score; CEO SMS if CRM_CEO_PHONE_E164 (or default)
# POST /api/crm/cron/enterprise-domain-scans — clients with monitored_domains → client_domain_scans
# POST /api/crm/cron/weekly-attacker-simulation — OpenAI → client_attacker_simulation_reports
# POST /api/crm/cron/aging — 10-day inactive prospects → SMS rep (OpenPhone)

# Phase 3 — monitor + monthly PDFs (same X-Cron-Secret as other crons)
# POST /api/monitor/health-check — logs to system_health_log, SMS CEO on double failure
# POST /api/crm/cron/monthly-reports — WeasyPrint PDF → Storage `reports` → Resend (portal email)
# MONITOR_API_BASE_URL=https://your-api.railway.app   # optional; else self-check uses http://127.0.0.1:$PORT/health
# MONITOR_EMAIL_FRESH_WARN_HOURS=2
# MONITOR_EMAIL_FRESH_FAIL_HOURS=48

# Optional integrations (set in Railway when features are enabled)
# SMARTLEAD_API_KEY=

# Apollo.io — optional; powers POST /api/crm/apollo/enrich
# APOLLO_API_KEY=your-apollo-key

# --- Railway hawk service — confirm for go-live (example names; use your project values) ---
# REDIS_URL=redis://default:...@redis.railway.internal:6379
# VA_PHONE_NUMBER=+1xxxxxxxxxx
# CAL_COM_BOOKING_URL=https://cal.com/your-team/onboarding
# STRIPE_PRICE_SHIELD=price_1THYpWRVvrqiS5j4rFdQclsd
# CRM_CEO_PHONE_E164=+18259458282
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=HAWK Security <noreply@securedbyhawk.com>
# OPENAI_API_KEY=sk-...   # Railway hawk API (portal AI, Ask HAWK, Charlotte, etc.)

# Scheduled jobs: prefer cron-job.org → Railway API (header X-Cron-Secret: same as HAWK_CRON_SECRET / CRON_SECRET).
# Do not rely on Vercel crons for production. Example base URL:
# https://hawk-production.up.railway.app
# POST /api/crm/cron/aging
# POST /api/crm/cron/onboarding-drip
# POST /api/crm/cron/stale-pipeline
# POST /api/crm/cron/monthly-reports
# POST /api/crm/cron/charlotte-run
# POST /api/crm/cron/daily-shield-rescan
# POST /api/crm/cron/weekly-threat-digest
# POST /api/crm/cron/dnstwist-daily
# POST /api/crm/cron/portal-milestones
# POST /api/crm/cron/rep-health-score
# POST /api/crm/cron/enterprise-domain-scans
# POST /api/crm/cron/weekly-attacker-simulation
# GET /health — must return 200
